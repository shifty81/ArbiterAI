<Window x:Class="ArbiterHost.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arbiter — Settings"
        Height="580" Width="680"
        MinHeight="520" MinWidth="580"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkBgBrush}"
        Loaded="Window_Loaded">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════ TAB CONTROL ══════════════ -->
        <TabControl Grid.Row="0" Margin="12,12,12,8" BorderThickness="1"
                    BorderBrush="{StaticResource BorderBrush}">

            <!-- ── Connection ── -->
            <TabItem Header="Connection">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <StackPanel Margin="16,16,16,16">

                        <TextBlock Text="Python Bridge" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,10"/>

                        <TextBlock Text="ArbiterAI bridge URL (port 8000):" Margin="0,0,0,4"
                                   Foreground="{StaticResource DimForegroundBrush}"/>
                        <TextBox Name="BridgeUrlBox" Margin="0,0,0,14" Padding="6,5"
                                 ToolTip="URL the WPF app uses to talk to fastapi_bridge.py"/>

                        <Separator Margin="0,4,0,12"/>
                        <TextBlock Text="Arbiter Engine" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,10"/>

                        <TextBlock Text="Arbiter Engine directory:" Margin="0,0,0,4"
                                   Foreground="{StaticResource DimForegroundBrush}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Name="EnginePathBox" Grid.Column="0" Padding="6,5"
                                     ToolTip="Full path to AIEngine/ArbiterEngine folder"/>
                            <Button Grid.Column="1" Content="…" Width="32" Margin="4,0,0,0"
                                    Click="BrowseEnginePath_Click" ToolTip="Browse…"/>
                        </Grid>

                        <TextBlock Text="Arbiter Engine port:" Margin="0,0,0,4"
                                   Foreground="{StaticResource DimForegroundBrush}"/>
                        <TextBox Name="EnginePortBox" Width="100" HorizontalAlignment="Left"
                                 Padding="6,5" Margin="0,0,0,14"
                                 ToolTip="Port number for the Arbiter Engine server (default 8001)"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── LLM Backend ── -->
            <TabItem Header="LLM Backend">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <StackPanel Margin="16,16,16,16">

                        <TextBlock Text="Active backend:" Margin="0,0,0,4"
                                   Foreground="{StaticResource DimForegroundBrush}"/>
                        <ComboBox Name="LlmBackendBox" Margin="0,0,0,14"
                                  SelectionChanged="LlmBackend_SelectionChanged"
                                  ToolTip="Select which LLM backend the engine uses">
                            <ComboBoxItem Content="ollama"     Tag="ollama"/>
                            <ComboBoxItem Content="embedded (llama-cpp-python — no external server)" Tag="embedded"/>
                            <ComboBoxItem Content="api (OpenAI-compatible)"   Tag="api"/>
                            <ComboBoxItem Content="anthropic"  Tag="anthropic"/>
                            <ComboBoxItem Content="gemini"     Tag="gemini"/>
                            <ComboBoxItem Content="lmstudio"   Tag="lmstudio"/>
                            <ComboBoxItem Content="localai"    Tag="localai"/>
                            <ComboBoxItem Content="llamacpp (server)"  Tag="llamacpp"/>
                            <ComboBoxItem Content="openwebui"  Tag="openwebui"/>
                        </ComboBox>

                        <!-- Embedded-only panel -->
                        <StackPanel Name="EmbeddedPanel">
                            <Separator Margin="0,0,0,12"/>
                            <TextBlock Text="Embedded backend (llama-cpp-python)" FontWeight="SemiBold"
                                       FontSize="13" Margin="0,0,0,10"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12"
                                       Foreground="{StaticResource DimForegroundBrush}">
                                Runs a GGUF model directly inside the Python process.
                                No Ollama or any external server is needed.
                                Install: pip install llama-cpp-python
                                GPU: CMAKE_ARGS="-DLLAMA_CUDA=on" pip install llama-cpp-python
                            </TextBlock>

                            <TextBlock Text="GGUF model file path:" Margin="0,0,0,4"
                                       Foreground="{StaticResource DimForegroundBrush}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Name="ModelPathBox" Grid.Column="0" Padding="6,5"
                                         ToolTip="Full path to a .gguf model file"/>
                                <Button Grid.Column="1" Content="…" Width="32" Margin="4,0,0,0"
                                        Click="BrowseModelPath_Click" ToolTip="Browse for GGUF file…"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Context size (tokens):" Margin="0,0,0,4"
                                               Foreground="{StaticResource DimForegroundBrush}"/>
                                    <TextBox Name="NCtxBox" Padding="6,5"
                                             ToolTip="Token context window (default 4096)"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="GPU layers (-1 = all):" Margin="0,0,0,4"
                                               Foreground="{StaticResource DimForegroundBrush}"/>
                                    <TextBox Name="NGpuLayersBox" Padding="6,5"
                                             ToolTip="-1 offloads all layers to GPU, 0 = CPU only"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Ollama hint panel -->
                        <StackPanel Name="OllamaPanel">
                            <Separator Margin="0,0,0,12"/>
                            <TextBlock Text="Ollama backend" FontWeight="SemiBold"
                                       FontSize="13" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource DimForegroundBrush}">
                                Ollama must be running at http://localhost:11434.
                                Download from https://ollama.ai then run:  ollama pull llama3
                            </TextBlock>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Voice ── -->
            <TabItem Header="Voice">
                <StackPanel Margin="16,16,16,16">

                    <TextBlock Text="Text-to-Speech" FontWeight="SemiBold"
                               FontSize="13" Margin="0,0,0,12"/>

                    <CheckBox Name="TtsEnabledBox" Content="Enable TTS voice output"
                              Margin="0,0,0,14"/>

                    <TextBlock Text="Default voice:" Margin="0,0,0,4"
                               Foreground="{StaticResource DimForegroundBrush}"/>
                    <ComboBox Name="VoiceBox" Width="260" HorizontalAlignment="Left"
                              Margin="0,0,0,14">
                        <ComboBoxItem Content="British_Female"/>
                        <ComboBoxItem Content="British_Male"/>
                        <ComboBoxItem Content="American_Female"/>
                        <ComboBoxItem Content="American_Male"/>
                    </ComboBox>

                </StackPanel>
            </TabItem>

            <!-- ── Projects ── -->
            <TabItem Header="Projects">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <StackPanel Margin="16,16,16,16">

                        <TextBlock Text="Workspace" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,10"/>

                        <TextBlock Text="Projects folder:" Margin="0,0,0,4"
                                   Foreground="{StaticResource DimForegroundBrush}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Name="ProjectsPathBox" Grid.Column="0" Padding="6,5"
                                     ToolTip="Root directory where Arbiter stores project workspaces"/>
                            <Button Grid.Column="1" Content="…" Width="32" Margin="4,0,0,0"
                                    Click="BrowseProjectsPath_Click" ToolTip="Browse…"/>
                        </Grid>

                        <TextBlock Text="Memory / conversation logs folder:" Margin="0,0,0,4"
                                   Foreground="{StaticResource DimForegroundBrush}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Name="MemoryPathBox" Grid.Column="0" Padding="6,5"
                                     ToolTip="Folder for conversation history SQLite databases"/>
                            <Button Grid.Column="1" Content="…" Width="32" Margin="4,0,0,0"
                                    Click="BrowseMemoryPath_Click" ToolTip="Browse…"/>
                        </Grid>

                        <Separator Margin="0,4,0,12"/>
                        <TextBlock Text="Git Identity" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Author name:" Margin="0,0,0,4"
                                           Foreground="{StaticResource DimForegroundBrush}"/>
                                <TextBox Name="GitNameBox" Padding="6,5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Author email:" Margin="0,0,0,4"
                                           Foreground="{StaticResource DimForegroundBrush}"/>
                                <TextBox Name="GitEmailBox" Padding="6,5"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ══════════════ FOOTER BUTTONS ══════════════ -->
        <Border Grid.Row="1"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="90" Margin="0,0,8,0"
                            Click="Cancel_Click"/>
                    <Button Name="SaveBtn" Content="Save" Width="90"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White" BorderThickness="0"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
