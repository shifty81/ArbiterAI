<Window x:Class="ArbiterHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arbiter" Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DarkBgBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid Background="{StaticResource DarkBgBrush}">

        <!-- CHAT VIEW (default) -->
        <Grid Name="ChatViewGrid" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource DarkBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo + toggle -->
                    <Grid Grid.Row="0" Margin="12,16,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#x2B21;  Arbiter AI"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Name="ChatToConfigBtn"
                                Content="&#x2699; Config" Padding="8,4"
                                ToolTip="Switch to Config / Developer mode"
                                Click="ViewToggle_Click"/>
                    </Grid>

                    <!-- New Chat button -->
                    <Button Grid.Row="1" Name="NewChatBtn"
                            Margin="8,0,8,4" Padding="10,8"
                            HorizontalContentAlignment="Left"
                            Click="NewChat_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="14" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="New Chat" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Scrollable: projects + personas -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,4,8,8">

                            <!-- PROJECTS -->
                            <Grid Margin="2,8,2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="PROJECTS" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource DimForegroundBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="+" Width="22" Height="22"
                                        Padding="0" FontSize="14"
                                        ToolTip="Create new project"
                                        Click="CreateProject_Click"/>
                            </Grid>
                            <ListBox Name="ChatProjectListBox"
                                     BorderThickness="0" Background="Transparent"
                                     Margin="0,0,0,4"
                                     SelectionChanged="ChatProjectListBox_SelectionChanged"/>

                            <!-- PERSONA -->
                            <TextBlock Text="PERSONA" Margin="2,12,2,4"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource DimForegroundBrush}"/>
                            <ListBox Name="ChatPersonaListBox"
                                     BorderThickness="0" Background="Transparent"
                                     SelectionChanged="ChatPersonaListBox_SelectionChanged"/>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- LLM + server status panel -->
                    <Border Grid.Row="3" Margin="8,0,8,12"
                            Background="{StaticResource PanelBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="10,8">
                        <StackPanel>

                            <!-- LLM status -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Name="LlmStatusDot"
                                         Width="8" Height="8" Fill="Gray"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Grid.Column="1" Name="LlmStatusText"
                                           Text="No LLM &#x2014; stub mode" FontSize="11"
                                           Foreground="{StaticResource DimForegroundBrush}"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Download panel (visible in stub mode) -->
                            <StackPanel Name="LlmNoModelPanel" Visibility="Collapsed">
                                <Button Name="DownloadModelBtn"
                                        Content="&#x2B07; Download model automatically"
                                        HorizontalAlignment="Stretch" Padding="6,6"
                                        Margin="0,4,0,4"
                                        Background="{StaticResource AccentBrush}"
                                        Foreground="White" BorderThickness="0"
                                        Click="DownloadModel_Click"/>
                                <ProgressBar Name="LlmDownloadProgress"
                                             Height="4" Minimum="0" Maximum="100" Value="0"
                                             Visibility="Collapsed" Margin="0,0,0,2"/>
                                <TextBlock Name="LlmDownloadStatusText"
                                           FontSize="10" Visibility="Collapsed"
                                           Foreground="{StaticResource DimForegroundBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                            </StackPanel>

                            <!-- Server status row -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Name="ChatServerDot"
                                         Width="8" Height="8" Fill="Gray"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Grid.Column="1" Name="ChatServerText"
                                           Text="Server offline" FontSize="11"
                                           Foreground="{StaticResource DimForegroundBrush}"/>
                                <Button Grid.Column="2" Name="ChatStartServerBtn"
                                        Content="Start" FontSize="10" Padding="4,2"
                                        Visibility="Collapsed"
                                        Click="StartServer_Click"/>
                            </Grid>

                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main chat area -->
            <Grid Grid.Column="1" Background="{StaticResource PanelBgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="20,10,16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Name="ChatViewHeader"
                                   Text="Select a project to start chatting"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Name="ChatExportBtn" Content="&#x1F4E5; Export"
                                    Width="78" Margin="0,0,6,0" IsEnabled="False"
                                    Click="ExportChat_Click"
                                    ToolTip="Export conversation to Markdown"/>
                            <Button Name="ChatRoadmapBtn" Content="&#x1F5FA; Roadmap"
                                    Width="86" IsEnabled="False"
                                    Click="GenerateRoadmap_Click"
                                    ToolTip="Generate AI implementation roadmap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Messages -->
                <ScrollViewer Grid.Row="1" Name="ChatViewScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Name="ChatMessageStack" Margin="24,16,24,8"/>
                </ScrollViewer>

                <!-- Input row -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="20,10,20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Name="ChatInput"
                                 Padding="10,8" FontSize="13"
                                 KeyDown="ChatInput_KeyDown"/>
                        <Button Grid.Column="1" Content="Send" Width="70"
                                Margin="8,0,0,0" Click="SendButton_Click"/>
                        <Button Grid.Column="2" Content="Mic" Width="38"
                                Margin="6,0,0,0" Click="MicButton_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- CONFIG VIEW (developer tools) -->
        <Grid Name="ConfigViewGrid"
              Visibility="Collapsed"
              Background="{StaticResource PanelBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="220" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0"
                    Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,4">
                        <TextBlock Text="Phase:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Name="PhaseSelector" Width="120" Margin="5"/>
                        <Separator Width="10"/>
                        <Button Name="CommitBtn" Content="Commit" Margin="2" Click="Commit_Click"/>
                        <Button Name="BranchBtn" Content="Branch" Margin="2" Click="Branch_Click"/>
                        <Button Name="PushBtn"   Content="Push"   Margin="2" Click="Push_Click"/>
                        <Button Name="PullBtn"   Content="Pull"   Margin="2" Click="Pull_Click"/>
                        <Button Name="LogBtn"    Content="Log"    Margin="2" Click="Log_Click"/>
                        <Separator Width="10"/>
                        <Button Name="BuildBtn"  Content="Build"  Margin="2" Click="Build_Click"/>
                        <Button Name="RunBtn"    Content="Run"    Margin="2" Click="Run_Click"/>
                        <Button Name="TestBtn"   Content="Test"   Margin="2" Click="Test_Click"/>
                        <Separator Width="10"/>
                        <TextBlock Text="Voice:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Name="VoiceSelector" Width="160" Margin="5">
                            <ComboBoxItem Content="British_Female" IsSelected="True"/>
                            <ComboBoxItem Content="British_Male"/>
                            <ComboBoxItem Content="American_Female"/>
                            <ComboBoxItem Content="American_Male"/>
                        </ComboBox>
                        <Separator Width="10"/>
                        <Ellipse Name="ServerStatusDot" Width="12" Height="12" Fill="Gray"
                                 VerticalAlignment="Center" Margin="4,0,2,0"/>
                        <TextBlock Name="ServerStatusText" Text="Server: ..."
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Button Name="StartServerButton" Content="Start Server" Margin="2"
                                Click="StartServer_Click"/>
                    </WrapPanel>
                    <Button Name="ConfigToChatBtn"
                            Content="Chat" Margin="0,4,8,4" Padding="8,4"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            ToolTip="Switch to Chat mode"
                            Click="ViewToggle_Click"/>
                </Grid>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1" Margin="4,6,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="140"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="2*" MinWidth="200"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"  MinWidth="140"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Direction="270"
                                          ShadowDepth="3" BlurRadius="8" Opacity="0.35"/>
                    </Border.Effect>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Projects" FontWeight="Bold"
                                   FontSize="13" Margin="0,0,0,6"/>
                        <ListBox Grid.Row="1" Name="ProjectListBox" AllowDrop="True"
                                 Drop="ProjectListBox_Drop"
                                 SelectionChanged="ProjectListBox_SelectionChanged"/>
                        <Button Grid.Row="2" Content="Create Project" Margin="0,6,0,2"
                                Click="CreateProject_Click"/>
                        <Button Grid.Row="3" Content="Self-Iterate (Arbiter)" Margin="0,2,0,0"
                                Click="OpenArbiterSelf_Click"
                                ToolTip="Load Arbiter's own source code so the AI can suggest improvements to itself"/>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="5"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <Border Grid.Column="2"
                        Background="{StaticResource PanelBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Direction="270"
                                          ShadowDepth="3" BlurRadius="8" Opacity="0.35"/>
                    </Border.Effect>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Name="ChatHeader" Text="Chat"
                                       FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Name="ExportChatBtn"
                                    Content="Export" Width="78" Margin="4,0,0,0"
                                    Click="ExportChat_Click" IsEnabled="False"
                                    ToolTip="Export conversation to chat_log.md"/>
                            <Button Grid.Column="2" Name="GenerateRoadmapBtn"
                                    Content="Roadmap" Width="86" Margin="4,0,0,0"
                                    Click="GenerateRoadmap_Click" IsEnabled="False"
                                    ToolTip="Ask Arbiter to generate an implementation roadmap"/>
                        </Grid>
                        <ListBox Grid.Row="1" Name="ChatDisplay"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        <Grid Grid.Row="2" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox  Grid.Column="0" Name="ConfigChatInput" Margin="0,0,5,0"
                                      KeyDown="ConfigChatInput_KeyDown"/>
                            <Button   Grid.Column="1" Content="Send" Width="60" Margin="0,0,5,0"
                                      Click="ConfigSendButton_Click"/>
                            <Button   Grid.Column="2" Content="Mic"  Width="60"
                                      Click="MicButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="3" Width="5"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <Border Grid.Column="4"
                        Background="{StaticResource PanelBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Direction="270"
                                          ShadowDepth="3" BlurRadius="8" Opacity="0.35"/>
                    </Border.Effect>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Suggestions / Roadmap"
                                   FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                        <ListBox Grid.Row="1" Name="SuggestionsListBox"/>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Approve" Width="80" Margin="0,0,5,0"
                                    Click="ApproveSuggestion_Click"/>
                            <Button Content="Move"    Width="80"
                                    Click="MoveSuggestion_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="2" Height="5"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Bottom panel -->
            <Border Grid.Row="3" Margin="4,2,4,6"
                    Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270"
                                      ShadowDepth="3" BlurRadius="8" Opacity="0.35"/>
                </Border.Effect>
                <TabControl Name="BottomTabControl" BorderThickness="0" Margin="0">
                    <TabItem Header="Project Files">
                        <TreeView Name="ProjectFilesTree" AllowDrop="True"
                                  Drop="ProjectFilesTree_Drop"/>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Build Output" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="Pop" Padding="3,1" FontSize="10"
                                        Click="PopOutBuildOutput_Click"
                                        ToolTip="Pop out Build Output into its own window"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TextBox Name="BuildOutputBox"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Courier New" FontSize="11" AcceptsReturn="True"/>
                    </TabItem>
                    <TabItem Header="Console">
                        <TabControl Name="ConsoleTabControl">
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="LLM" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Button Content="Copy" Padding="4,1" FontSize="10"
                                                Click="CopyLlmConsole_Click"/>
                                    </StackPanel>
                                </TabItem.Header>
                                <TextBox Name="LlmConsoleBox" IsReadOnly="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Courier New" FontSize="11" AcceptsReturn="True"/>
                            </TabItem>
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="App" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Button Content="Copy" Padding="4,1" FontSize="10"
                                                Click="CopyAppConsole_Click"/>
                                    </StackPanel>
                                </TabItem.Header>
                                <TextBox Name="AppConsoleBox" IsReadOnly="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Courier New" FontSize="11" AcceptsReturn="True"/>
                            </TabItem>
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Server" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Button Content="Copy" Padding="4,1" FontSize="10"
                                                Click="CopyServerConsole_Click"/>
                                    </StackPanel>
                                </TabItem.Header>
                                <TextBox Name="ServerConsoleBox" IsReadOnly="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Courier New" FontSize="11" AcceptsReturn="True"/>
                            </TabItem>
                        </TabControl>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- GEAR BUTTON - always visible, bottom-right -->
        <Button Name="GearBtn"
                Content="&#x2699;" FontSize="15" Width="40" Height="40" Padding="0"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,12,12"
                ToolTip="Settings"
                Click="GearBtn_Click"/>

        <!-- TOAST CONTAINER - above gear button -->
        <StackPanel Name="ToastContainer"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,12,60" Width="320"
                    IsHitTestVisible="False"/>

    </Grid>
</Window>
