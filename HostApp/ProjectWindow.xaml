<Window x:Class="ArbiterHost.ProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arbiter Project" Height="850" Width="1200"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <!-- Top Bar: Phase selector, Git buttons, Build buttons, Voice selector, Server status -->
        <WrapPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="Phase:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox Name="PhaseSelector" Width="120" Margin="5"/>
            <Separator Width="10"/>
            <Button Content="Commit" Margin="2" Click="Commit_Click"/>
            <Button Content="Branch" Margin="2" Click="Branch_Click"/>
            <Button Content="Push"   Margin="2" Click="Push_Click"/>
            <Button Content="Pull"   Margin="2" Click="Pull_Click"/>
            <Button Content="Log"    Margin="2" Click="Log_Click"/>
            <Separator Width="10"/>
            <Button Content="Build"  Margin="2" Click="Build_Click"/>
            <Button Content="Run"    Margin="2" Click="Run_Click"/>
            <Button Content="Test"   Margin="2" Click="Test_Click"/>
            <Separator Width="10"/>
            <TextBlock Text="Voice:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox Name="VoiceSelector" Width="160" Margin="5">
                <ComboBoxItem Content="British_Female" IsSelected="True"/>
                <ComboBoxItem Content="British_Male"/>
                <ComboBoxItem Content="American_Female"/>
                <ComboBoxItem Content="American_Male"/>
            </ComboBox>
            <Separator Width="10"/>
            <Ellipse Name="ServerStatusDot" Width="12" Height="12" Fill="Gray"
                     VerticalAlignment="Center" Margin="4,0,2,0"/>
            <TextBlock Name="ServerStatusText" Text="Server: checking…"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Button Name="StartServerButton" Content="Start Server" Margin="2"
                    Click="StartServer_Click"/>
        </WrapPanel>

        <!-- Middle: Chat Panel + Suggestions Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Chat Panel -->
            <StackPanel Grid.Column="0" Margin="5">
                <TextBlock Text="Chat" FontWeight="Bold" Margin="0,0,0,3"/>
                <ListBox Name="ChatDisplay" Height="450" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBox Name="ChatInput" Width="380" Margin="0,0,5,0"/>
                    <Button Content="Send" Width="60" Margin="0,0,5,0" Click="SendButton_Click"/>
                    <Button Content="Mic"  Width="60" Click="MicButton_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Suggestions / Roadmap Panel -->
            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock Text="Suggestions / Roadmap" FontWeight="Bold" Margin="0,0,0,3"/>
                <ListBox Name="SuggestionsListBox" Height="450"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Button Content="Approve" Width="80" Margin="0,0,5,0" Click="ApproveSuggestion_Click"/>
                    <Button Content="Move"    Width="80" Click="MoveSuggestion_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Bottom: Tabs for Project Files and Build Output -->
        <TabControl Name="BottomTabControl" Grid.Row="2" Margin="5">
            <TabItem Header="Project Files">
                <TreeView Name="ProjectFilesTree" AllowDrop="True" Drop="ProjectFilesTree_Drop"/>
            </TabItem>
            <TabItem Header="Build Output">
                <TextBox Name="BuildOutputBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Courier New"
                         FontSize="11"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         AcceptsReturn="True"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
